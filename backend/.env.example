# Backend Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=5000

# Supabase (get from https://app.supabase.com > Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT Secret — gunakan string acak yang panjang
JWT_SECRET=ganti-dengan-string-rahasia-yang-sangat-panjang-dan-acak
JWT_EXPIRES_IN=7d

# EA Secret — shared key untuk EA auto-register (tanpa perlu isi BridgeToken manual)
# Buat string acak, set di Railway, lalu isi di input EaSecret pada SeizeBridge EA
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EA_SECRET=ganti-dengan-string-rahasia-acak-untuk-ea

# MT4 Bridge (tidak dipakai jika pakai WebRequest EA)
MT4_BRIDGE_PORT=9090
MT4_BRIDGE_HOST=0.0.0.0
MT4_DEMO_MODE=false

# CORS — set ke URL Railway kamu setelah deploy (contoh: https://seizeweb.up.railway.app)
FRONTEND_URL=https://your-app.up.railway.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# SMTP Email (untuk alert offline MT4)
# Contoh pakai Gmail: SMTP_HOST=smtp.gmail.com, PORT=465, gunakan App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
